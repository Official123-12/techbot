{
  "name": "stany-host",
  "description": "WhatsApp Bot Hosting Platform with SQ Coins",
  "repository": "https://github.com/stanytz/Stany-Hosting",
  "stack": "heroku-24",
  "buildpacks": [{ "url": "heroku/nodejs" }],
  "env": {
    "MONGODB_URI": { "description": "MongoDB Atlas connection string", "required": true },
    "JWT_SECRET": { "description": "Secret key for JWT signing", "generator": "secret", "required": true },
    "SESSION_SECRET": { "description": "Secret for cookie sessions", "generator": "secret", "required": true },
    "TIGERPAY_PUBLIC_KEY": { "description": "TigerPayPro public API key", "required": true },
    "TIGERPAY_SECRET_KEY": { "description": "TigerPayPro secret API key", "required": true },
    "HEROKU_API_KEY": { "description": "API key for deploying bots", "required": true },
    "ADMIN_EMAIL": { "description": "Admin email for dashboard access", "value": "stanytz@gmail.com", "required": true },
    "ADMIN_USERNAME": { "description": "Admin dashboard username", "value": "stanytz", "required": true },
    "ADMIN_PHONE": { "description": "Admin phone number for Min Pay confirmations", "value": "255787069580", "required": true },
    "APP_URL": { "description": "Public URL of this app", "value": "https://stanyhost.herokuapp.com", "required": true },
    "IMAGE_URL": { "description": "Logo image URL shown in the app header and branding areas", "value": "https://stanyhost.herokuapp.com/logo.png" },
    "BOT_TOKEN": { "description": "Telegram bot token for admin notifications", "required": false },
    "BOT_OWNER_ID": { "description": "Your Telegram user ID to receive bot notifications", "required": false }
  }
}