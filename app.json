{
  "name": "toxic-host",
  "description": "WhatsApp Bot Hosting Platform with TX Coins",
  "repository": "https://github.com/xhclintohn/Toxic-Hosting",
  "stack": "heroku-24",
  "buildpacks": [{ "url": "heroku/nodejs" }],
  "env": {
    "MONGODB_URI": { "description": "MongoDB Atlas connection string", "required": true },
    "JWT_SECRET": { "description": "Secret key for JWT signing", "generator": "secret", "required": true },
    "SESSION_SECRET": { "description": "Secret for cookie sessions", "generator": "secret", "required": true },
    "PAYSTACK_PUBLIC_KEY": { "description": "Paystack public API key", "required": true },
    "PAYSTACK_SECRET_KEY": { "description": "Paystack secret API key", "required": true },
    "HEROKU_API_KEY": { "description": "API key for deploying bots", "required": true },
    "ADMIN_USERNAME": { "description": "Admin dashboard username", "required": true },
    "ADMIN_PASSWORD": { "description": "Admin dashboard password", "required": true },
    "APP_URL": { "description": "Public URL of this app", "value": "https://hosting.toxicx.tech", "required": true },
    "IMAGE_URL": { "description": "Logo image URL shown in the app header and branding areas", "value": "example.jpg" },
    "BOT_TOKEN": { "description": "Telegram bot token for admin notifications", "required": false },
    "BOT_OWNER_ID": { "description": "Your Telegram user ID to receive bot notifications", "required": false }
  }
}
